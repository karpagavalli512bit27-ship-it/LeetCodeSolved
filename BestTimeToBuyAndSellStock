class Solution {
    public int maxProfit(int[] prices) {
        int max=0;
        int n=prices.length;
        int price=prices[0];
        for(int i=1;i<n;i++){
            if(price>prices[i]){
                price=prices[i];
            }
            else if(prices[i]-price>max){
                max=prices[i]-price;
            }
        }
        return max;
    }
}
