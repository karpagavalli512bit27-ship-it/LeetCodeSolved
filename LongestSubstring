int lengthOfLongestSubstring(char* s) {
    int index[128] = {0};
    int maxLen = 0, start = 0;

    for (int i = 0; s[i] != '\0'; i++) {
        char c = s[i];
        if (index[(int)c] > start) {
            start = index[(int)c];
        }
        int currentLen = i - start + 1;
        if (currentLen > maxLen) {
            maxLen = currentLen;
        }
        index[(int)c] = i + 1; 
    }

    return maxLen;
}
